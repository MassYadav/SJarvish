# ==========================================
# AI OS ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# Instructions: Copy this file to '.env' and fill in your keys.
# NEVER commit the actual '.env' file to version control.

# ------------------------------------------
# 1. CORE BACKEND SETTINGS
# ------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8085
# Generate a random string for this (e.g., using `openssl rand -hex 32`)
SECRET_KEY=your_super_secret_encryption_key_here

# ------------------------------------------
# 2. LLM ROUTER (LITELLM BYOK)
# ------------------------------------------
# Provide at least one key to enable the fallback chain
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ------------------------------------------
# 3. DATABASES & MEMORY LAYER
# ------------------------------------------
# These match the docker-compose.yml ports we just spun up
REDIS_URL=redis://localhost:6379/0
CHROMA_DB_URL=http://localhost:8000
# SQLite is used for local LangGraph state checkpointing
SQLITE_DB_PATH=./sqlite_data/aios_state.db

# ------------------------------------------
# 4. VOICE SYSTEM (LIVEKIT)
# ------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ------------------------------------------
# 5. FRONTEND DASHBOARD
# ------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8085
NEXT_PUBLIC_WS_URL=ws://localhost:8085/ws