# FastAPI Backend Configuration
BACKEND_HOST=localhost
BACKEND_PORT=8000
BACKEND_ENV=development

# Database Configuration
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://ai_os:postgres@localhost:5432/ai_os
SQLITE_DB_PATH=./data/ai_os.db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ChromaDB Configuration
CHROMADB_URL=http://localhost:8000
CHROMADB_COLLECTION=ai_os_embeddings

# LiteLLM Router Configuration
LITELLM_MASTER_KEY=your_master_key_here
LLM_MODEL_PRIMARY=gpt-4
LLM_MODEL_FALLBACK=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Security Configuration
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Observability Configuration
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# MCP Configuration
ENABLE_MCP_TOOLS=true

# Environment Variables for Local Development
DEBUG=false
